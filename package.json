{
  "name": "motxt",
  "publisher": "csui-rse-lab",
  "displayName": "MoTxT - Model-to-Text Code Generator",
  "description": "Generate Django and FastAPI backend code from UML class diagrams using model-to-text transformation.",
  "version": "1.0.3",
  "icon": "media/logo.png",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "motxt.runAcceleoGenerator",
        "title": "MoTxT: Run Acceleo Generator"
      },
      {
        "command": "motxt.openUserManual",
        "title": "MoTxT: Open User Manual"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "motxt-sidebar",
          "title": "MoTxT",
          "icon": "media/logo.svg"
        }
      ]
    },
    "views": {
      "motxt-sidebar": [
        {
          "id": "motxtSidebarView",
          "name": "MoTxT",
          "type": "webview",
          "icon": "media/logo.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "child_process": "^1.0.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "marked": "^18.0.2",
    "npm-run-all": "^4.1.5",
    "path": "^0.12.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
